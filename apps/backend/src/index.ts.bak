const express = require('express');
const cors = require('cors');
const swaggerJsdoc = require('swagger-jsdoc');
const swaggerUi = require('swagger-ui-express');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const mongoose = require('mongoose');
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const archiver = require('archiver');
const kyroAI = require('../../../packages/kyro-ai/engine.js');

const app = express();
const PORT = process.env.PORT || 3001;

app.use(cors());
app.use(express.json());

// MongoDB connection
const MONGODB_URI = process.env.MONGODB_URI || 'mongodb://localhost:27017/kyro';
mongoose.connect(MONGODB_URI)
  .then(() => console.log('✅ Connected to MongoDB'))
  .catch(err => console.error('❌ MongoDB connection error:', err));

const swaggerOptions = {
  definition: {
    openapi: '3.0.0',
    info: {
      title: 'Kyro API',
      version: '0.0.1',
      description: 'Kyro AI Website Generator API',
    },
    servers: [
      {
        url: 'http://localhost:3001',
        description: 'Development server',
      },
    ],
  },
  apis: ['./src/index.ts'],
};

const swaggerSpec = swaggerJsdoc(swaggerOptions);
app.use('/api-docs', swaggerUi.serve, swaggerUi.setup(swaggerSpec));

const GENERATED_PROJECTS_DIR = path.join(__dirname, '..', 'generated-projects');
const TEMPLATES_DIR = path.join(__dirname, '..', 'templates');
const PROJECTS_METADATA = new Map();

const generateProjectId = () => {
  const timestamp = Date.now();
  const random = crypto.randomBytes(4).toString('hex');
  return `project-${timestamp}-${random}`;
};

const readTemplate = (templateName) => {
  const templatePath = path.join(TEMPLATES_DIR, templateName);
  return fs.readFileSync(templatePath, 'utf-8');
};

const ensureDir = (dirPath) => {
  if (!fs.existsSync(dirPath)) {
    fs.mkdirSync(dirPath, { recursive: true });
    console.log(`Created directory: ${dirPath}`);
  }
};

const writeFile = (filePath, content) => {
  const dir = path.dirname(filePath);
  ensureDir(dir);
  fs.writeFileSync(filePath, content);
  console.log(`Created file: ${filePath}`);
};

const createPackageJson = (projectId, websiteType) => {
  return JSON.stringify({
    name: `generated-app-${projectId}`,
    version: '1.0.0',
    description: `Generated ${websiteType} website`,
    main: 'backend/index.js',
    scripts: {
      start: 'node backend/index.js',
      dev: 'nodemon backend/index.js'
    },
    dependencies: {
      express: '^4.18.0',
      cors: '^2.8.5',
      jsonwebtoken: '^9.0.0',
      stripe: '^14.0.0'
    },
    devDependencies: {
      nodemon: '^3.0.0'
    }
  }, null, 2);
};

const createReadme = (projectId, websiteType, features) => {
  return `# Generated App - ${projectId}\n\n## Project Type\n${websiteType}\n\n## Features\n${features.map(f => `- ${f}`).join('\n')}\n\n## Structure\n- \`frontend/\` - Frontend application\n- \`backend/\` - Backend API server\n  - \`middleware/\` - Auth middleware (if enabled)\n  - \`routes/\` - API routes\n  - \`controllers/\` - Request handlers\n  - \`services/\` - Business logic\n\n## Getting Started\n\n1. Install dependencies:\n   \`\`\`bash\n   npm install\n   \`\`\`\n\n2. Start the backend:\n   \`\`\`bash\n   npm start\n   \`\`\`\n\n## Generated by Kyro\nTimestamp: ${new Date().toISOString()}\n`;
};

const getBackendIndex = (features) => {
  const routes = [];
  const requires = [];

  if (features.includes('payments')) {
    routes.push("app.use('/api/payments', require('./routes/payment.routes'))");
    requires.push("const paymentRoutes = require('./routes/payment.routes');");
  }
  if (features.includes('admin')) {
    routes.push("app.use('/api/admin', require('./routes/admin.routes'))");
    requires.push("const adminRoutes = require('./routes/admin.routes');");
  }

  return `const express = require('express');
const app = express();
const PORT = process.env.PORT || 3002;

app.use(express.json());

${requires.join('\n')}

${routes.join('\n')}

app.get('/', (req, res) => {
  res.json({ message: 'Generated backend API' });
});

app.listen(PORT, () => {
  console.log(\`Backend running on port \${PORT}\`);
});
`;
};

const JWT_SECRET = process.env.JWT_SECRET || 'your-secret-key-change-in-production';

const authMiddleware = (req, res, next) => {
  try {
    const authHeader = req.headers.authorization;
    if (!authHeader) {
      return res.status(401).json({ success: false, error: 'No token provided' });
    }

    const token = authHeader.split(' ')[1];
    if (!token) {
      return res.status(401).json({ success: false, error: 'No token provided' });
    }

    const decoded = jwt.verify(token, JWT_SECRET);
    req.user = {
      id: decoded.id,
      username: decoded.username,
      email: decoded.email
    };
    next();
  } catch (error) {
    return res.status(401).json({ success: false, error: 'Invalid or expired token' });
  }
};

const generateToken = (user) => {
  return jwt.sign(
    { id: user.id, username: user.username, email: user.email },
    JWT_SECRET,
    { expiresIn: '7d' }
  );
};

// User Schema
const userSchema = new mongoose.Schema({
  username: { type: String, required: true, unique: true },
  email: { type: String, required: true, unique: true },
  password: { type: String, required: true },
  createdAt: { type: Date, default: Date.now }
});

userSchema.pre('save', async function(next) {
  if (!this.isModified('password')) return next();
  const salt = await bcrypt.genSalt(10);
  this.password = await bcrypt.hash(this.password, salt);
  next();
});

userSchema.methods.comparePassword = async function(password) {
  return await bcrypt.compare(password, this.password);
};

const User = mongoose.model('User', userSchema);

// Project Schema
const projectSchema = new mongoose.Schema({
  projectId: { type: String, required: true, unique: true },
  userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User', required: true },
  websiteType: { type: String, required: true },
  features: [String],
  modules: [String],
  structure: [String],
  downloadPath: String,
  createdAt: { type: Date, default: Date.now }
});

const Project = mongoose.model('Project', projectSchema);

/**
 * @openapi
 * /auth/signup:
 *   post:
 *     summary: User signup
 *     tags: [Auth]
 *     requestBody:
 *       required: true
 *       content:
 *         application/json:
 *           schema:
 *             type: object
 *             required: [username, email, password]
 *             properties:
 *               username: { type: string }
 *               email: { type: string }
 *               password: { type: string }
 *     responses:
 *       200:
 *         description: User created successfully
 */
app.post('/auth/signup', async (req, res) => {
  try {
    const { username, email, password } = req.body;

    if (!username || !email || !password) {
      return res.status(400).json({ success: false, error: 'Missing required fields' });
    }

    const existingUser = await User.findOne({ $or: [{ email }, { username }] });
    if (existingUser) {
      return res.status(400).json({ success: false, error: 'User already exists' });
    }

    const user = new User({ username, email, password });
    await user.save();

    const token = generateToken({ id: user._id.toString(), username: user.username, email: user.email });

    console.log(`✅ New user registered: ${username}`);
    res.json({ success: true, data: { token, user: { id: user._id, username: user.username, email: user.email } } });
  } catch (error) {
    res.status(500).json({ success: false, error: error.message });
  }
});

/**
 * @openapi
 * /auth/login:
 *   post:
 *     summary: User login
 *     tags: [Auth]
 *     requestBody:
 *       required: true
 *       content:
 *         application/json:
 *           schema:
 *             type: object
 *             required: [email, password]
 *             properties:
 *               email: { type: string }
 *               password: { type: string }
 *     responses:
 *       200:
 *         description: Login successful
 */
app.post('/auth/login', async (req, res) => {
  try {
    const { email, password } = req.body;

    const user = await User.findOne({ email });
    if (!user || !(await user.comparePassword(password))) {
      return res.status(401).json({ success: false, error: 'Invalid credentials' });
    }

    const token = generateToken({ id: user._id.toString(), username: user.username, email: user.email });

    console.log(`✅ User logged in: ${user.username}`);
    res.json({ success: true, data: { token, user: { id: user._id, username: user.username, email: user.email } } });
  } catch (error) {
    res.status(500).json({ success: false, error: error.message });
  }
});

/**
 * @openapi
 * /generate:
 *   post:
 *     summary: Generate project structure
 *     description: Generates a project with files based on website type and features
 *     tags:
 *       - Generator
 *     security:
 *       - bearerAuth: []
 *     requestBody:
 *       required: true
 *       content:
 *         application/json:
 *           schema:
 *             type: object
 *             required:
 *               - websiteType
 *               - features
 *             properties:
 *               websiteType:
 *                 type: string
 *                 enum: [basic, ecommerce, social, blog]
 *                 example: ecommerce
 *               features:
 *                 type: array
 *                 items:
 *                   type: string
 *                   enum: [auth, payments, admin]
 *                 example: ["auth", "payments"]
 *     responses:
 *       200:
 *         description: Successfully generated project structure
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 success:
 *                   type: boolean
 *                   example: true
 *                 data:
 *                   type: object
 *                   properties:
 *                     projectId:
 *                       type: string
 *                     downloadPath:
 *                       type: string
 *                     previewUrl:
 *                       type: string
 *                     structure:
 *                       type: array
 *                       items:
 *                         type: string
 *                     modules:
 *                       type: array
 *                       items:
 *                         type: string
 *       400:
 *         description: Missing required fields
 */
app.post('/generate', authMiddleware, async (req, res) => {
  const { websiteType, features } = req.body;

  if (!websiteType || !features) {
    const response = {
      success: false,
      error: 'Missing required fields: websiteType and features'
    };
    return res.status(400).json(response);
  }

  try {
    const projectId = generateProjectId();
    const basePath = path.join(GENERATED_PROJECTS_DIR, projectId);
    const structure = [];

    console.log(`\n🤖 Kyro AI Engine: Generating project ${projectId}`);
    console.log(`📂 Location: ${basePath}`);

    // Step 1: AI Engine generates the plan
    const userConfig = { websiteType, features, techPreferences: {} };
    const plan = kyroAI.generatePlan(userConfig);

    console.log(`📋 Generation Plan:`);
    console.log(`   Website Type: ${plan.websiteType}`);
    console.log(`   Resolved Features: ${plan.resolvedFeatures.join(', ')}`);
    console.log(`   Modules: ${plan.modules.map(m => m.name).join(', ')}`);

    ensureDir(basePath);
    structure.push('frontend/');
    structure.push('backend/');

    const backendPath = path.join(basePath, 'backend');
    ensureDir(backendPath);

    // Step 2: Generator writes files based on plan
    plan.modules.forEach((module) => {
      console.log(`  📦 Processing module: ${module.name}`);
      module.files.forEach((file) => {
        const filePath = path.join(basePath, file.path);
        const content = readTemplate(file.template);
        writeFile(filePath, content);
        structure.push(file.path);
      });
    });

    // Generate backend index
    const indexPath = path.join(backendPath, 'index.js');
    writeFile(indexPath, getBackendIndex(features));
    structure.push('backend/index.js');

    // Generate package.json and README
    const packageJsonPath = path.join(basePath, 'package.json');
    writeFile(packageJsonPath, createPackageJson(projectId, websiteType));
    structure.push('package.json');

    const readmePath = path.join(basePath, 'README.md');
    writeFile(readmePath, createReadme(projectId, websiteType, features));
    structure.push('README.md');

    structure.push('frontend/');

    // Save project to database
    const project = new Project({
      projectId,
      userId: req.user.id,
      websiteType,
      features,
      modules: plan.modules.map(m => m.name),
      structure,
      downloadPath: basePath
    });
    await project.save();

    // Store project metadata
    const metadata = {
      projectId,
      websiteType,
      features,
      modules: plan.modules.map(m => m.name),
      structure,
      downloadPath: basePath,
      previewUrl: `/preview/${projectId}`,
      createdAt: new Date().toISOString()
    };
    PROJECTS_METADATA.set(projectId, metadata);

    console.log(`✅ Project ${projectId} generated successfully via AI Engine!\n`);

    const response = {
      success: true,
      data: {
        projectId,
        downloadPath: basePath,
        previewUrl: `/preview/${projectId}`,
        structure,
        modules: plan.modules.map(m => m.name),
        message: `Project generated using AI Engine. Modules: ${plan.modules.map(m => m.name).join(', ')}`
      }
    };

    res.json(response);
  } catch (error) {
    console.error(`❌ Error generating project:`, error.message);
    const response = {
      success: false,
      error: error.message
    };
    res.status(500).json(response);
  }
});

/**
 * @openapi
 * /download/{projectId}:
 *   get:
 *     summary: Download generated project as ZIP
 *     description: Compresses the project folder and returns a downloadable ZIP file
 *     tags:
 *       - Download
 *     parameters:
 *       - in: path
 *         name: projectId
 *         required: true
 *         schema:
 *           type: string
 *         description: The project ID to download
 *     responses:
 *       200:
 *         description: ZIP file download
 *         content:
 *           application/zip:
 *             schema:
 *               type: string
 *               format: binary
 *       404:
 *         description: Project not found
 */
app.get('/download/:projectId', (req, res) => {
  const { projectId } = req.params;
  const projectPath = path.join(GENERATED_PROJECTS_DIR, projectId);

  console.log(`\n📦 Download request for project: ${projectId}`);

  if (!fs.existsSync(projectPath)) {
    console.log(`❌ Project not found: ${projectId}`);
    return res.status(404).json({
      success: false,
      error: `Project ${projectId} not found`
    });
  }

  const zipFileName = `kyro-project-${projectId}.zip`;

  res.setHeader('Content-Type', 'application/zip');
  res.setHeader('Content-Disposition', `attachment; filename=${zipFileName}`);

  const archive = archiver('zip', {
    zlib: { level: 9 }
  });

  archive.on('error', (err) => {
    console.error(`❌ Archive error:`, err.message);
    res.status(500).json({
      success: false,
      error: 'Failed to create ZIP file'
    });
  });

  archive.on('end', () => {
    console.log(`✅ Download completed: ${zipFileName} (${archive.pointer()} bytes)`);
  });

  archive.pipe(res);
  archive.directory(projectPath, false);
  archive.finalize();
});

/**
 * @openapi
 * /project/{projectId}:
 *   get:
 *     summary: Get project metadata
 *     description: Returns full project metadata and structure
 *     tags:
 *       - Project
 *     security:
 *       - bearerAuth: []
 *     parameters:
 *       - in: path
 *         name: projectId
 *         required: true
 *         schema:
 *           type: string
 *         description: The project ID
 *     responses:
 *       200:
 *         description: Project metadata
 *       404:
 *         description: Project not found
 */
app.get('/project/:projectId', authMiddleware, async (req, res) => {
  const { projectId } = req.params;

  console.log(`\n🔍 Metadata request for project: ${projectId}`);

  const project = await Project.findOne({ projectId, userId: req.user.id });
  if (!project) {
    return res.status(404).json({
      success: false,
      error: `Project ${projectId} not found`
    });
  }

  const metadata = PROJECTS_METADATA.get(projectId) || {
    projectId: project.projectId,
    websiteType: project.websiteType,
    features: project.features,
    modules: project.modules,
    structure: project.structure,
    downloadPath: project.downloadPath,
    previewUrl: `/preview/${projectId}`,
    createdAt: project.createdAt
  };

  console.log(`✅ Returned metadata for: ${projectId}`);
  res.json({
    success: true,
    data: metadata
  });
});

/**
 * @openapi
 * /projects:
 *   get:
 *     summary: Get user's projects
 *     tags: [Projects]
 *     security:
 *       - bearerAuth: []
 *     responses:
 *       200:
 *         description: List of user's projects
 */
app.get('/projects', authMiddleware, async (req, res) => {
  try {
    const projects = await Project.find({ userId: req.user.id }).sort('-createdAt');
    console.log(`✅ Returned ${projects.length} projects for user: ${req.user.username}`);

    res.json({
      success: true,
      data: projects.map(p => ({
        projectId: p.projectId,
        websiteType: p.websiteType,
        features: p.features,
        modules: p.modules,
        createdAt: p.createdAt,
        previewUrl: `/preview/${p.projectId}`
      }))
    });
  } catch (error) {
    res.status(500).json({ success: false, error: error.message });
  }
});

app.get('/preview/:projectId', (req, res) => {
  const { projectId } = req.params;
  const projectPath = path.join(GENERATED_PROJECTS_DIR, projectId);

  if (!fs.existsSync(projectPath)) {
    return res.status(404).send('Project not found');
  }

  const html = `
<!DOCTYPE html>
<html>
<head>
  <title>Kyro Preview - ${projectId}</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <div class="min-h-screen p-8">
    <div class="max-w-4xl mx-auto">
      <div class="bg-white shadow rounded-lg p-6 mb-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Kyro Preview</h1>
        <p class="text-gray-600">Project: ${projectId}</p>
      </div>

      <div class="bg-white shadow rounded-lg p-6 mb-6">
        <h2 class="text-xl font-semibold mb-4">Project Structure</h2>
        <div id="structure" class="bg-gray-50 p-4 rounded font-mono text-sm"></div>
      </div>

      <div class="flex gap-4">
        <a href="/download/${projectId}" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
          Download ZIP
        </a>
        <a href="/api-docs" class="bg-gray-300 text-gray-700 px-6 py-2 rounded hover:bg-gray-400">
          Back to API
        </a>
      </div>
    </div>
  </div>
  <script>
    fetch('/project/${projectId}')
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          const structure = data.data.structure;
          document.getElementById('structure').innerHTML =
            structure.map(f => '📄 ' + f).join('<br>');
        }
      });
  </script>
</body>
</html>
  `;

  res.send(html);
});

app.listen(PORT, () => {
  console.log(`Backend server running on http://localhost:${PORT}`);
  console.log(`Swagger docs available at http://localhost:${PORT}/api-docs`);
});
